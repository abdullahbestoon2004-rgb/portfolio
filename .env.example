# Frontend
# Local development uses the mock API by default.
# Set this to false if you want the Vite dev server to talk to the Express API.
VITE_USE_MOCK_API=true

# Backend
MONGO_URI=mongodb+srv://your-user:your-password@your-cluster.mongodb.net/portfolio_cms
JWT_SECRET=replace-this-with-a-long-random-secret
